# Configuracoes do projeto
PROJECT_NAME=Sistema de Gestao de Pessoas
API_V1_STR=/api/v1
ENVIRONMENT=development

# ============================================
# SUPABASE DATABASE - Usar Session Pooler (IPv4)
# ============================================
#
# IMPORTANTE: Use a connection string do SESSION POOLER, nao a direta.
#
# No Supabase Dashboard:
# 1. Va em: Settings > Database > Connection string
# 2. Selecione "Session pooler" em vez de "Direct connection"
# 3. Copie a connection string completa
#
# Formato Session Pooler:
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Override opcional para Supabase/producao:
# DATABASE_URL=postgresql://postgres.project-ref:SuaSenha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Postgres local via Docker Compose
POSTGRES_HOST=localhost
POSTGRES_DB=alpha
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5434

# Seguranca - alterar em producao.
# Gere uma chave forte. Exemplo:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-esta-chave-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Producao: defina ENVIRONMENT=production e uma SECRET_KEY forte.
# python -c "import secrets; print(secrets.token_urlsafe(64))"
# METRICS_API_KEY=gere-uma-chave-para-monitoramento

# Bootstrap da conta master/admin inicial
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_PASSWORD=change-me
MASTER_ADMIN_NAME=Administrador Master
MASTER_ADMIN_CPF=00000000000
MASTER_ADMIN_PIS=00000000000
MASTER_ADMIN_PHONE=

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Google Maps
GOOGLE_MAPS_API_KEY=

# MinIO / S3 compatible storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=sgp-presencas
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_PRESIGNED_URLS=false
MINIO_PRESIGNED_EXPIRES_SECONDS=3600
METRICS_API_KEY=

# MinIO local via Docker Compose
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Email / Resend
EMAIL_ENABLED=false
EMAIL_FROM=noreply@alpha.com
FRONTEND_URL=http://localhost:5173
RESEND_API_KEY=

# WhatsApp (serviço Baileys em Alpha/whatsapp-service)
WHATSAPP_ENABLED=false
WHATSAPP_SERVICE_URL=http://localhost:3100
WHATSAPP_SERVICE_TOKEN=change-me-whatsapp-token
WHATSAPP_PORT=3100
WHATSAPP_SEND_DELAY_MIN_MS=3000
WHATSAPP_SEND_DELAY_MAX_MS=5000
